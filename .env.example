# ═══════════════════════════════════════════════════════════════
# Signer: 아래 세 옵션 중 정확히 하나만 채울 것 (자동 감지 순서: AWS > GCP > PK)
# ═══════════════════════════════════════════════════════════════

# ── Option A) Private key (개발용, 간단) ─────────────────────────
# scripts/create-wallet.ts 실행 결과의 priv key 를 그대로 붙여넣기.
FAUCET_PRIVATE_KEY=

# ── Option B) AWS KMS (권장, 프로덕션) ────────────────────────────
# ECC_SECG_P256K1 asymmetric key 필요. IAM: kms:GetPublicKey, kms:Sign
# AWS_REGION=us-east-1
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxx-xxxx-xxxx-xxxx
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Option C) GCP KMS ────────────────────────────────────────────
# Elliptic Curve P-256 (secp256k1) asymmetric sign key 필요.
# GCP_PROJECT_ID=
# GCP_LOCATION_ID=global
# GCP_KEYRING_ID=
# GCP_KEY_ID=
# GCP_KEY_VERSION=1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# 또는 GCP_KEY_FILENAME 로 override

# ═══════════════════════════════════════════════════════════════
# App config
# ═══════════════════════════════════════════════════════════════

# 한 번의 faucet 요청에 지급할 Giwa Sepolia ETH 양 (주소당 24시간에 1회)
FAUCET_DRIP_AMOUNT_ETH=0.005

# 매일 cron 이 L1 잔고를 확인해 이 값 이상이면 브릿징 실행
BRIDGE_THRESHOLD_ETH=0.1

# 브릿징 시 L1 에 남길 gas 예비 잔고 (bridge 금액 = L1 잔고 - reserve)
BRIDGE_RESERVE_ETH=0.05

# Vercel Cron 인증용 secret. Vercel Cron 은 자동으로
# Authorization: Bearer $CRON_SECRET 헤더를 붙임.
# 설정 안 하면 인증 우회 (테스트용). 프로덕션에서는 반드시 설정.
CRON_SECRET=

# ═══════════════════════════════════════════════════════════════
# RPC endpoints (선택. 미설정 시 viem 기본값 = 공용 RPC)
# 프로덕션에서는 자체 RPC (Alchemy, Infura 등) 권장.
# ═══════════════════════════════════════════════════════════════
# 서버사이드 (cron / faucet API 에서 사용)
# L1_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# L2_RPC_URL=https://sepolia-rpc.giwa.io

# 클라이언트사이드 (사용자 지갑 브릿지에서 사용, 브라우저에 노출됨)
# 서버사이드와 동일한 값으로 두면 됨. 노출되므로 API key 없는 공용 RPC 권장.
# NEXT_PUBLIC_L1_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# NEXT_PUBLIC_L2_RPC_URL=https://sepolia-rpc.giwa.io

# ═══════════════════════════════════════════════════════════════
# Bridge UI (사용자 본인 지갑으로 L1<->L2 브릿징)
# ═══════════════════════════════════════════════════════════════
# WalletConnect Cloud (https://cloud.walletconnect.com) 에서 발급.
# 없으면 브라우저 injected 지갑(MetaMask, Rabby 등)만 사용 가능.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
